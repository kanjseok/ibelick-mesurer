{
  "name": "mesurer",
  "description": "Measure and align elements on any website.",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --filter mesurer build && pnpm --filter mesurer-site build",
    "build:extension": "pnpm --filter mesurer-extension build",
    "deploy:site": "pnpm --filter mesurer-site deploy:pages",
    "build:site": "pnpm --filter mesurer-site build",
    "build:pkg": "pnpm --filter mesurer build",
    "dev": "pnpm -r dev",
    "dev:site": "pnpm --filter mesurer-site dev",
    "dev:pkg": "pnpm --filter mesurer dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  }
}
